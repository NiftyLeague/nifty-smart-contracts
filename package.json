{
  "name": "@niftyleague/smart-contracts",
  "version": "1.0.0",
  "description": "Nifty League Smart Contracts",
  "author": "Nifty Andy",
  "license": "MIT",
  "homepage": "https://github.com/NiftyLeague/nifty-smart-contracts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NiftyLeague/nifty-smart-contracts"
  },
  "bugs": {
    "url": "https://github.com/NiftyLeague/nifty-smart-contracts/issues"
  },
  "scripts": {
    "compile": "hardhat clean && hardhat compile",
    "build": "pnpm compile",
    "format:ts": "prettier --ignore-path .prettierignore --write .",
    "format:sol": "prettier --write --plugin=prettier-plugin-solidity \"src/contracts/**/*.sol\"",
    "format": "pnpm format:ts && pnpm format:sol",
    "format:check": "prettier --ignore-path .prettierignore --check .",
    "lint:ts": "eslint --ignore-path .eslintignore . --ext .ts,.js --fix",
    "lint:ts:check": "eslint --ignore-path .eslintignore . --ext .ts,.js --max-warnings=0",
    "lint:sol": "solhint \"src/contracts/**/*.sol\" --ignore-path .solhintignore",
    "lint": "pnpm lint:ts && pnpm lint:sol",
    "type-check": "tsc --noEmit",
    "test": "hardhat test --typecheck --network hardhat",
    "coverage": "hardhat coverage",
    "test:coverage": "pnpm coverage && node scripts/check-coverage.mjs",
    "slither": "slither . --checklist --markdown-root ./ > SLITHER.md",
    "generate-merkle-root": "ts-node src/scripts/merkle-distributor/generate-merkle-root.ts",
    "generate-merkle-root:balance-manager": "pnpm generate-merkle-root --input src/data/dynamodb_account_balances.json",
    "verify-merkle-root": "ts-node src/scripts/merkle-distributor/verify-merkle-root.ts --input src/data/merkle-result.json",
    "deploy:hardhat": "hardhat deploy --network hardhat",
    "deploy:tenderly": "hardhat deploy --network tenderly",
    "deploy:sepolia": "hardhat deploy --network sepolia",
    "deploy:mainnet": "hardhat deploy --network mainnet",
    "deploy:imx:testnet": "hardhat deploy --network imtbl-zkevm-testnet",
    "deploy:imx:mainnet": "hardhat deploy --network imtbl-zkevm-mainnet",
    "export:sepolia": "pnpm deploy:sepolia --export exports/deployments.sepolia.ts",
    "export:mainnet": "pnpm deploy:mainnet --export exports/deployments.mainnet.ts",
    "export:imx:testnet": "pnpm deploy:imx:testnet --export exports/deployments.imxTestnet.ts",
    "export:imx:mainnet": "pnpm deploy:imx:mainnet --export exports/deployments.imxMainnet.ts",
    "export": "pnpm export:sepolia && pnpm export:mainnet && pnpm export:imx:testnet && pnpm export:imx:mainnet && prettier --ignore-path .prettierignore --write exports/*.ts",
    "verify:imx:testnet": "pnpm verify --network imtbl-zkevm-testnet --show-stack-traces",
    "verify:imx:mainnet": "pnpm verify --network imtbl-zkevm-mainnet --show-stack-traces",
    "verify": "hardhat etherscan-verify"
  },
  "devDependencies": {
    "@axelar-network/axelarjs-sdk": "^0.16.2",
    "@axelar-network/interchain-token-service": "^1.2.4",
    "@chainlink/contracts": "^1.2.0",
    "@imtbl/contracts": "3.1.1",
    "@nomicfoundation/hardhat-chai-matchers": "^3.0.0",
    "@nomicfoundation/hardhat-ethers": "^4.0.14",
    "@nomicfoundation/hardhat-ignition": "^3.1.8",
    "@nomicfoundation/hardhat-ignition-ethers": "^3.1.6",
    "@nomicfoundation/hardhat-ledger": "^3.0.10",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.11",
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@nomicfoundation/hardhat-verify": "^3.0.21",
    "@openzeppelin/contracts": "^5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "@openzeppelin/hardhat-upgrades": "^4.0.2",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.19",
    "@types/mocha": "^10.0.8",
    "@types/node": "^26.1.1",
    "@types/ramda": "^0.32.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "chai": "^6.2.2",
    "chalk": "^5.3.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.1",
    "eth-provider": "^0.13.7",
    "ethers": "^6.13.2",
    "fs": "0.0.1-security",
    "hardhat": "^3.9.1",
    "hardhat-deploy": "^2.0.9",
    "hardhat-deploy-ethers": "^0.4.2",
    "hardhat-gas-reporter": "^2.2.1",
    "husky": "^9.1.6",
    "lint-staged": "^17.0.8",
    "mocha": "^11.7.6",
    "prettier": "^3.3.3",
    "prettier-plugin-solidity": "^2.3.1",
    "ramda": "^0.32.0",
    "solhint": "^6.2.3",
    "solhint-plugin-prettier": "^0.1.0",
    "solidity-bytes-utils": "^0.8.2",
    "solidity-coverage": "^0.8.13",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typechain": "^8.3.2",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.13.1"
  },
  "packageManager": "pnpm@11.13.1"
}
