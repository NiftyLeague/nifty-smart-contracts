{
  "name": "@niftyleague/smart-contracts",
  "version": "1.0.0",
  "description": "Nifty League Smart Contracts",
  "author": "Nifty Andy",
  "license": "MIT",
  "homepage": "https://github.com/NiftyLeague/nifty-smart-contracts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NiftyLeague/nifty-smart-contracts"
  },
  "bugs": {
    "url": "https://github.com/NiftyLeague/nifty-smart-contracts/issues"
  },
  "scripts": {
    "compile": "hardhat clean && hardhat compile",
    "build": "hardhat clean && hardhat compile",
    "format:ts": "prettier --ignore-path .prettierignore --write .",
    "format:sol": "prettier --write --plugin=prettier-plugin-solidity \"src/contracts/**/*.sol\"",
    "format": "bun format:ts && bun format:sol",
    "lint:ts": "eslint --ignore-path .eslintignore . --ext .ts,.js --fix",
    "lint:sol": "solhint \"src/contracts/**/*.sol\" --ignore-path .solhintignore",
    "lint": "bun lint:ts && bun lint:sol",
    "type-check": "tsc --noEmit",
    "type:check": "tsc --noEmit",
    "start": "hardhat node",
    "dev": "hardhat node --watch",
    "test": "hardhat test src/test/*.ts --typecheck --network hardhat",
    "coverage": "hardhat coverage",
    "slither": "slither . --checklist --markdown-root ./ > SLITHER.md",
    "generate-merkle-root": "ts-node src/scripts/merkle-distributor/generate-merkle-root.ts",
    "generate-merkle-root:balance-manager": "bun generate-merkle-root --input src/data/dynamodb_account_balances.json",
    "verify-merkle-root": "ts-node src/scripts/merkle-distributor/verify-merkle-root.ts --input src/data/merkle-result.json",
    "deploy:hardhat": "hardhat deploy --network hardhat",
    "deploy:tenderly": "hardhat deploy --network tenderly",
    "deploy:sepolia": "hardhat deploy --network sepolia",
    "deploy:mainnet": "hardhat deploy --network mainnet",
    "deploy:imx:testnet": "hardhat deploy --network imtbl-zkevm-testnet",
    "deploy:imx:mainnet": "hardhat deploy --network imtbl-zkevm-mainnet",
    "export:sepolia": "bun deploy:sepolia --export exports/deployments.sepolia.ts",
    "export:mainnet": "bun deploy:mainnet --export exports/deployments.mainnet.ts",
    "export:imx:testnet": "bun deploy:imx:testnet --export exports/deployments.imxTestnet.ts",
    "export:imx:mainnet": "bun deploy:imx:mainnet --export exports/deployments.imxMainnet.ts",
    "export": "bun export:sepolia && bun export:mainnet && bun export:imx:testnet && bun export:imx:mainnet && prettier --ignore-path .prettierignore --write exports/*.ts",
    "verify:imx:testnet": "bun verify --network imtbl-zkevm-testnet --show-stack-traces",
    "verify:imx:mainnet": "bun verify --network imtbl-zkevm-mainnet --show-stack-traces",
    "verify": "hardhat etherscan-verify",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@axelar-network/axelarjs-sdk": "^0.16.2",
    "@axelar-network/interchain-token-service": "^1.2.4",
    "@chainlink/contracts": "^1.2.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.7",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-ignition": "^0.15.5",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.5",
    "@nomicfoundation/hardhat-ledger": "^1.0.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.11",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.10",
    "@openzeppelin/contracts": "^4.9.6",
    "@openzeppelin/contracts-upgradeable": "^4.9.6",
    "@openzeppelin/hardhat-upgrades": "^3.3.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.19",
    "@types/mocha": "^10.0.8",
    "@types/node": "^20.16.5",
    "@types/ramda": "^0.29.12",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "chai": "^4.5.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eth-provider": "^0.13.7",
    "ethers": "^6.13.2",
    "fs": "0.0.1-security",
    "hardhat": "^2.22.10",
    "hardhat-deploy": "^0.12.4",
    "hardhat-deploy-ethers": "^0.4.2",
    "hardhat-gas-reporter": "^2.2.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "mocha": "^10.7.3",
    "prettier": "^3.3.3",
    "prettier-plugin-solidity": "^1.4.1",
    "ramda": "^0.29.1",
    "solhint": "^5.0.3",
    "solhint-plugin-prettier": "^0.1.0",
    "solidity-bytes-utils": "^0.8.2",
    "solidity-coverage": "^0.8.13",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typechain": "^8.3.2",
    "typescript": "^5.6.2",
    "@imtbl/contracts": "^3.1.1"
  },
  "engines": {
    "node": ">=20.x"
  },
  "packageManager": "bun@1.3.14"
}